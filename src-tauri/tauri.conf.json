{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lumina",
  "version": "0.0.1",
  "identifier": "com.jackfu.lumina",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lumina",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyQ0U0N0QwM0I2OTc2MkMKUldRc2RtazcwRWZPRWhSWTFqbVB4ZXhNamhWWlc2MDRSZVBZbUtGSzl4SW9LZUJ6VW9XSkhsOGcK",
      "endpoints": [
        "https://github.com/rommel-exe/lumina/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
